# ============================================
# SyncBricks Configuration
# ============================================
# Copy to .env and fill in your values:
#   cp .env.example .env

# --- Database ---
DATABASE_URL=./data/syncbricks.db

# --- Proxmox Servers ---
PROXMOX_NODE1_HOST=10.11.12.101
PROXMOX_NODE1_USER=root@pam
PROXMOX_NODE1_API_TOKEN_ID=
PROXMOX_NODE1_API_TOKEN_SECRET=

PROXMOX_NODE2_HOST=10.11.12.104
PROXMOX_NODE2_USER=root@pam
PROXMOX_NODE2_API_TOKEN_ID=
PROXMOX_NODE2_API_TOKEN_SECRET=

# --- pfSense Firewall ---
PFSENSE_HOST=
PFSENSE_USER=admin
PFSENSE_API_KEY=
PFSENSE_API_SECRET=

# --- Docker ---
DOCKER_HOST=
DOCKER_PORT=2375

# --- Pi-hole ---
PIHOLE_HOST=
PIHOLE_API_TOKEN=

# --- AdGuard Home ---
ADGUARD_HOST=
ADGUARD_USER=admin
ADGUARD_PASSWORD=

# --- TrueNAS ---
TRUENAS_HOST=
TRUENAS_API_KEY=

# --- NUT (UPS) ---
NUT_HOST=
NUT_PORT=3493

# --- Nginx Proxy Manager ---
NPM_HOST=
NPM_USER=
NPM_PASSWORD=

# --- Network ---
HOMELAB_SUBNET=10.11.12.0/24
HOMELAB_GATEWAY=
HOMELAB_DNS_PRIMARY=
HOMELAB_DNS_SECONDARY=
HOMELAB_DOMAIN=

# --- AI Providers (optional) ---
OLLAMA_ENDPOINT=http://localhost:11434
OPENAI_API_KEY=
AI_MODEL=llama3
