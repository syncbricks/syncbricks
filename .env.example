# ============================================
# SyncBricks Configuration
# ============================================
# Copy to .env and fill in your values:
#   cp .env.example .env
#
# NOTE: Infrastructure connections (Proxmox, Docker, pfSense, etc.)
# are managed from the UI at Settings > Connections.
# You can add multiple instances of any type from the dashboard.
# The ENV variables below are only needed for app-level config.

# --- Database ---
DATABASE_URL=./data/syncbricks.db

# --- Network ---
HOMELAB_SUBNET=10.11.12.0/24
HOMELAB_GATEWAY=
HOMELAB_DNS_PRIMARY=
HOMELAB_DNS_SECONDARY=
HOMELAB_DOMAIN=

# --- AI Providers (optional) ---
OLLAMA_ENDPOINT=http://localhost:11434
OPENAI_API_KEY=
AI_MODEL=llama3

# --- SSH Key (optional, recommended) ---
# SyncBricks auto-detects SSH keys on the host machine.
# If this server's SSH key is added to your infrastructure hosts'
# authorized_keys, SyncBricks can connect without storing passwords.
#
# To set up passwordless access (at your own risk):
#   1. Generate a key (if you don't have one):
#      ssh-keygen -t ed25519 -C "syncbricks"
#   2. Copy it to each target host:
#      ssh-copy-id root@10.11.12.101
#      ssh-copy-id root@10.11.12.104
#   3. SyncBricks will detect and use it automatically.
#
# SSH_KEY_PATH=~/.ssh/id_ed25519
